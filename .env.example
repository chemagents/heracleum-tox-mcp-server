# --- MCP transport (matches the other CoScientist MCP servers) ---
HERACLEUM_MCP_HOST=0.0.0.0
HERACLEUM_MCP_PORT=7331
HERACLEUM_MCP_PATH=/mcp

# --- Dataset (bundled in the package; rebuild with `uv run python build_dataset.py`) ---
# HERACLEUM_DATASET_PATH=/app/server/data/heracleum_metabolites.csv

# --- Chemical space / clustering (open-source SynMap analogue) ---
HERACLEUM_MORGAN_RADIUS=2
HERACLEUM_MORGAN_NBITS=2048
HERACLEUM_N_CLUSTERS=5
HERACLEUM_TSNE_PERPLEXITY=15
HERACLEUM_RANDOM_STATE=42

# --- ML models (open analogue of Syntelly CatBoost/XGBoost) ---
HERACLEUM_MODEL_BACKEND=catboost          # catboost | xgboost (classification always uses XGBoost)
HERACLEUM_RETRAIN=false
# HERACLEUM_MODEL_CACHE_DIR=/app/server/model_cache
# HERACLEUM_TDC_DIR=tdc_data               # where PyTDC caches downloaded datasets

# --- Applicability domain (paper Section 2.5: kNN k=5 + Gaussian) ---
HERACLEUM_AD_K_NEIGHBORS=5
HERACLEUM_AD_THRESHOLD_SIGMA=2.0

# --- Exact per-route LD50 reproduction (optional) ---
# Drop TOXRIC per-route CSVs (columns: smiles,y with y = -log10(mol/kg)) named
# ld50_<route>.csv (route in oral,iv,ip,sc,skin,im) into this dir to train
# route-specific models instead of sharing the open acute-LD50 model.
# HERACLEUM_LD50_DATA_DIR=/app/ld50_routes

# --- Synthesis cost (open analogue of Syntelly Synthesis cost) ---
# Optional ASKCOS retrosynthesis service (reuse chemical-mcp-server's) for novel molecules.
# HERACLEUM_ASKCOS_URL=
HERACLEUM_SYNTHESIS_MAX_STEPS=6

# --- Figure artifacts: local dir (default) or S3-compatible bucket ---
HERACLEUM_ARTIFACTS_DIR=/app/artifacts
# HERACLEUM_ARTIFACT_URL_BASE=
HERACLEUM_S3_ENDPOINT_URL=
HERACLEUM_S3_BUCKET_NAME=
HERACLEUM_S3_ACCESS_KEY=
HERACLEUM_S3_SECRET_KEY=
